NODE_ENV=staging
PORT=3001
DATABASE_URL=postgresql://bandkit_user:change_me@127.0.0.1:5432/bandkit
# Set to true once the VPS serves over HTTPS (TLS). Makes the session cookie Secure.
COOKIE_SECURE=false
# 32-byte hex key (64 chars) for encrypting TOTP secrets at rest. Generate: openssl rand -hex 32
TWOFACTOR_KEK=
