NODE_ENV=staging
PORT=3001
DATABASE_URL=postgresql://bandkit_user:change_me@127.0.0.1:5432/bandkit
# Set to true once the VPS serves over HTTPS (TLS). Makes the session cookie Secure.
COOKIE_SECURE=false
# 32-byte hex key (64 chars) for encrypting TOTP secrets at rest. Generate: openssl rand -hex 32
TWOFACTOR_KEK=

# Outbound mail. 'none' (default) sends nothing and lets non-production return a
# dev verification token instead. Set to 'resend' to send real email.
MAIL_PROVIDER=none
# Resend API key (https://resend.com) — required when MAIL_PROVIDER=resend.
RESEND_API_KEY=
# Verified sender, e.g. "BandKit <noreply@yourdomain>". Resend's test sender
# "BandKit <onboarding@resend.dev>" only delivers to your own account address.
MAIL_FROM=
# Public origin used to build links in emails (no trailing slash).
APP_BASE_URL=https://bandkitdev.mywire.org
